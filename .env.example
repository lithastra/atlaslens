# MongoDB
ATLASLENS_MONGO_URI=mongodb://localhost:27017
ATLASLENS_MONGO_DB=atlaslens

# Auth
ATLASLENS_JWT_SECRET=change-me-to-a-random-secret

# Field-level encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ATLASLENS_ENCRYPTION_KEY=

# Atlassian Cloud
ATLASLENS_ATLASSIAN_SITE=your-domain
ATLASLENS_ATLASSIAN_ORG_ID=
ATLASLENS_ATLASSIAN_EMAIL=
ATLASLENS_ATLASSIAN_API_TOKEN=

# Atlassian OAuth (alternative to API token)
ATLASLENS_ATLASSIAN_OAUTH_CLIENT_ID=
ATLASLENS_ATLASSIAN_OAUTH_CLIENT_SECRET=

# Bitbucket
ATLASLENS_BITBUCKET_WORKSPACE=
ATLASLENS_BITBUCKET_APP_PASSWORD=

# Ingestion schedule (minutes)
ATLASLENS_INGEST_INTERVAL_MINUTES=15
