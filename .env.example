# MongoDB
ATLASLENS_MONGO_URI=mongodb://localhost:27017
ATLASLENS_MONGO_DB=atlaslens

# Auth
ATLASLENS_JWT_SECRET=change-me-to-a-random-secret

# Field-level encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ATLASLENS_ENCRYPTION_KEY=

# Atlassian Cloud
ATLASLENS_ATLASSIAN_SITE=your-domain
ATLASLENS_ATLASSIAN_CLOUD_ID=
ATLASLENS_ATLASSIAN_ORG_ID=
ATLASLENS_ATLASSIAN_EMAIL=

# Scoped API tokens (create at id.atlassian.com/manage-profile/security/api-tokens)
# Jira token scopes: read:audit-log:jira, read:jira-work, read:jira-user, read:events:admin, read:request:jira-service-management
ATLASLENS_JIRA_API_TOKEN=
# Confluence token scopes: read:audit-log:confluence, read:page:confluence, read:content-details:confluence
ATLASLENS_CONFLUENCE_API_TOKEN=
# Bitbucket token scopes: read:repository:bitbucket, read:pullrequest:bitbucket
ATLASLENS_BITBUCKET_API_TOKEN=

# Atlassian OAuth (alternative to API tokens)
ATLASLENS_ATLASSIAN_OAUTH_CLIENT_ID=
ATLASLENS_ATLASSIAN_OAUTH_CLIENT_SECRET=

# Bitbucket
ATLASLENS_BITBUCKET_WORKSPACE=

# CORS (JSON array of allowed origins)
ATLASLENS_CORS_ORIGINS=["http://localhost:5173"]

# Ingestion schedule (minutes)
ATLASLENS_INGEST_INTERVAL_MINUTES=15
